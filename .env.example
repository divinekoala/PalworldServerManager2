# ─────────────────────────────────────────────────────────────────────────────
# Palworld Server Manager configuration
# Copy this file to ".env" and fill in the values. The .env file is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Web UI ──────────────────────────────────────────────────────────────────
# Port the manager's web UI listens on (Caddy reverse-proxies to this).
WEB_PORT=8080
# Bind address. Keep 127.0.0.1 so only Caddy (on the same machine) can reach it.
WEB_HOST=127.0.0.1
# Set true when served over HTTPS through Caddy so the session cookie gets the
# Secure flag. Set false if you are testing over plain http://localhost.
SECURE_COOKIES=true

# ── Palworld server process (Windows) ────────────────────────────────────────
# Full path to PalServer.exe
PAL_SERVER_EXE=C:\\PalServer\\PalServer.exe
# Working directory for the server (usually the folder PalServer.exe lives in).
# Leave blank to default to the exe's directory.
PAL_SERVER_CWD=
# Extra launch arguments (space separated). These are common performance flags.
PAL_SERVER_ARGS=-useperfthreads -NoAsyncLoadingThread -UseMultithreadForDS

# ── Palworld REST API (localhost only — never port-forward this) ─────────────
# Enable in PalWorldSettings.ini: RESTAPIEnabled=True and RESTAPIPort=8212
REST_API_BASE=http://127.0.0.1:8212
REST_API_USER=admin
# Equal to AdminPassword in PalWorldSettings.ini
REST_API_PASSWORD=your-palworld-admin-password

# ── Auto save + shutdown ─────────────────────────────────────────────────────
# Save and shut down after this many minutes with 0 players online.
EMPTY_SHUTDOWN_MINUTES=15
# How often (seconds) to poll the player count while the server is ON.
POLL_INTERVAL_SECONDS=60

# ── Transition timeouts (seconds) ────────────────────────────────────────────
# How long to wait for the server to become reachable after starting.
START_READY_TIMEOUT_SECONDS=180
# How long to wait for a graceful shutdown before force-killing the process.
STOP_TIMEOUT_SECONDS=120
# Countdown (seconds) passed to the Palworld shutdown command.
SHUTDOWN_GRACE_SECONDS=10

# ── Web UI authentication ────────────────────────────────────────────────────
# Generate with: npm run hash-password
ADMIN_PASSWORD_HASH=
# Random secret used to sign session cookies. Generate any long random string,
# e.g. with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=
# Session lifetime in hours.
SESSION_TTL_HOURS=24

# ── DuckDNS (used by deploy/ scripts and docs; not required at runtime) ───────
DUCKDNS_DOMAIN=yoursubdomain
DUCKDNS_TOKEN=your-duckdns-token
