# ─────────────────────────────────────────────────────────────────────────────
# Docker configuration for the Palworld Server Manager stack.
# Copy this file to ".env" (same folder as docker-compose.yml) and fill it in.
# Paths/host are set by the image and docker-compose, so they are NOT needed here.
# ─────────────────────────────────────────────────────────────────────────────

# ── Palworld server / REST API ───────────────────────────────────────────────
# This becomes the server's AdminPassword AND the credential the manager uses
# for the REST API (they must match — using one value guarantees that).
# NOTE: docker-compose treats "$" specially. If your password contains a "$",
# write it as "$$" here (e.g. pa$$word -> pa$$$$word), or just avoid "$".
REST_API_PASSWORD=choose-a-strong-admin-password
# Shown in the server browser. Used only when first creating PalWorldSettings.ini.
SERVER_NAME=My Palworld Server
# Re-validate/update the game via SteamCMD on every container start.
UPDATE_ON_BOOT=true

# ── Auto save + shutdown ─────────────────────────────────────────────────────
EMPTY_SHUTDOWN_MINUTES=15
POLL_INTERVAL_SECONDS=60

# Optional transition timeouts (seconds). If you raise STOP_TIMEOUT_SECONDS,
# also raise `stop_grace_period` in docker-compose.yml to match.
# START_READY_TIMEOUT_SECONDS=180
# STOP_TIMEOUT_SECONDS=120
# SHUTDOWN_GRACE_SECONDS=10

# ── Web UI authentication ────────────────────────────────────────────────────
# Generate with:  docker compose run --rm palworld-manager npm run hash-password
ADMIN_PASSWORD_HASH=
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# ── DuckDNS (used by the Caddy service for HTTPS) ────────────────────────────
DUCKDNS_DOMAIN=yoursubdomain
DUCKDNS_TOKEN=your-duckdns-token
